<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Le Repère des Protocoles{% endblock %}</title>
        <meta name="turbo-cache-control" content="no-cache">
        {% block head %}{% endblock %}
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-gray-50 flex flex-col">

        <nav class="bg-brand-bleu-fonce shadow-md" data-controller="navbar">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

                {# ── Barre principale ──────────────────────────────── #}
                <div class="flex justify-between h-16 items-center">

                    {# Logo #}
                    <a href="{{ path('app_home') }}" class="text-base sm:text-xl font-bold text-white shrink-0">
                        Le Repère des Protocoles
                    </a>

                    {# Ordinateur (lg+) : tous les liens en ligne #}
                    <div class="hidden lg:flex items-center gap-2 text-base">
                        {% if app.user %}
                            <a href="{{ path('profil_index') }}"
                               class="flex items-center gap-2 text-white/80 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded-md transition-colors">
                                <span class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center text-white text-xs font-bold shrink-0 select-none">
                                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                                </span>
                                {{ app.user.prenom }} {{ app.user.nom }}
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="relative" data-controller="dropdown">
                                    <button data-action="click->dropdown#toggle"
                                            class="flex items-center gap-1 text-white/90 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded-md focus:outline-none transition-colors">
                                        Administration
                                        <svg class="h-3.5 w-3.5 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </button>
                                    <div data-dropdown-target="menu"
                                         class="hidden absolute top-full right-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 py-1 z-50">
                                        <a href="{{ path('admin_demande_index') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-bleu-fonce-light hover:text-brand-bleu-fonce">Demandes</a>
                                        <a href="{{ path('admin_utilisateur_index') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-bleu-fonce-light hover:text-brand-bleu-fonce">Utilisateurs</a>
                                        <a href="{{ path('admin_profession_index') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-bleu-fonce-light hover:text-brand-bleu-fonce">Professions</a>
                                    </div>
                                </div>
                            {% endif %}

                            {% if is_granted('ROLE_MODERATEUR') %}
                                <div class="relative" data-controller="dropdown">
                                    <button data-action="click->dropdown#toggle"
                                            class="flex items-center gap-1 text-white/90 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded-md focus:outline-none transition-colors">
                                        Modération
                                        <svg class="h-3.5 w-3.5 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </button>
                                    <div data-dropdown-target="menu"
                                         class="hidden absolute top-full right-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 py-1 z-50">
                                        <a href="{{ path('moderateur_domaine_index') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-bleu-fonce-light hover:text-brand-bleu-fonce">Domaines</a>
                                        <a href="{{ path('moderateur_rubrique_index') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-bleu-fonce-light hover:text-brand-bleu-fonce">Rubriques</a>
                                        <a href="{{ path('moderateur_theme_index') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-bleu-fonce-light hover:text-brand-bleu-fonce">Thèmes</a>
                                        <a href="{{ path('moderateur_protocole_index') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-bleu-fonce-light hover:text-brand-bleu-fonce">Protocoles</a>
                                    </div>
                                </div>
                            {% endif %}

                            <a href="{{ path('navigation_domaines') }}"
                               class="bg-white text-brand-bleu-fonce font-medium px-4 py-1.5 rounded-md hover:bg-white/90 transition-colors">
                                Parcourir
                            </a>
                            <form action="{{ path('app_logout') }}" method="post" class="inline" data-turbo="false">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                <button type="submit"
                                        class="bg-brand-rose text-white hover:bg-brand-rose-dark px-3 py-1.5 rounded-md cursor-pointer font-medium transition-colors border-0">
                                    Déconnexion
                                </button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_inscription') }}"
                               class="text-white/80 border border-white/30 hover:text-white hover:border-white px-4 py-1.5 rounded-md transition-colors">
                                S'inscrire
                            </a>
                            <a href="{{ path('app_login') }}"
                               class="bg-white text-brand-bleu-fonce font-medium px-4 py-1.5 rounded-md hover:bg-white/90 transition-colors">
                                Connexion
                            </a>
                        {% endif %}
                    </div>

                    {# Tablette + Téléphone (< lg) : liens rapides + hamburger #}
                    <div class="flex lg:hidden items-center gap-3">

                        {# Tablette uniquement (md à lg) : nom + Parcourir en ligne #}
                        <div class="hidden md:flex items-center gap-3 text-sm">
                            {% if app.user %}
                                <a href="{{ path('profil_index') }}" class="text-white/80 hover:text-white">
                                    {{ app.user.prenom }} {{ app.user.nom }}
                                </a>
                                <a href="{{ path('navigation_domaines') }}" class="text-white font-medium hover:text-white/80">Parcourir</a>
                            {% else %}
                                <a href="{{ path('app_login') }}" class="text-white font-medium hover:text-white/80">Connexion</a>
                            {% endif %}
                        </div>

                        {# Bouton hamburger #}
                        <button
                            type="button"
                            data-action="click->navbar#toggle"
                            class="p-2 rounded-md text-white/80 hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/50"
                            aria-label="Ouvrir le menu"
                        >
                            <svg data-navbar-target="iconOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                            </svg>
                            <svg data-navbar-target="iconClose" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>

                    </div>
                </div>

                {# ── Menu déroulant (téléphone + tablette) ─────────── #}
                <div data-navbar-target="menu" class="hidden lg:hidden border-t border-white/20">
                    <div class="py-3 flex flex-col gap-0.5 text-sm">
                        {% if app.user %}

                            {# Profil avec avatar #}
                            <a href="{{ path('profil_index') }}"
                               class="flex items-center gap-2 px-3 py-2 text-white hover:bg-white/10 rounded-md font-medium">
                                <span class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center text-white text-xs font-bold shrink-0 select-none">
                                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                                </span>
                                {{ app.user.prenom }} {{ app.user.nom }}
                            </a>

                            <a href="{{ path('navigation_domaines') }}" class="block px-3 py-2 text-white font-medium hover:bg-white/10 rounded-md">
                                Parcourir les protocoles
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <p class="px-3 pt-4 pb-1 text-xs font-semibold text-white/40 uppercase tracking-wide">Administration</p>
                                <a href="{{ path('admin_demande_index') }}" class="block px-3 py-2 text-white/90 hover:bg-white/10 rounded-md">Demandes</a>
                                <a href="{{ path('admin_utilisateur_index') }}" class="block px-3 py-2 text-white/90 hover:bg-white/10 rounded-md">Utilisateurs</a>
                                <a href="{{ path('admin_profession_index') }}" class="block px-3 py-2 text-white/90 hover:bg-white/10 rounded-md">Professions</a>
                            {% endif %}

                            {% if is_granted('ROLE_MODERATEUR') %}
                                <p class="px-3 pt-4 pb-1 text-xs font-semibold text-white/40 uppercase tracking-wide">Modération</p>
                                <a href="{{ path('moderateur_domaine_index') }}" class="block px-3 py-2 text-white/90 hover:bg-white/10 rounded-md">Domaines</a>
                                <a href="{{ path('moderateur_rubrique_index') }}" class="block px-3 py-2 text-white/90 hover:bg-white/10 rounded-md">Rubriques</a>
                                <a href="{{ path('moderateur_theme_index') }}" class="block px-3 py-2 text-white/90 hover:bg-white/10 rounded-md">Thèmes</a>
                                <a href="{{ path('moderateur_protocole_index') }}" class="block px-3 py-2 text-white/90 hover:bg-white/10 rounded-md">Protocoles</a>
                            {% endif %}

                            <div class="mt-2 pt-2 border-t border-white/20">
                                <form action="{{ path('app_logout') }}" method="post" data-turbo="false">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                    <button type="submit" class="w-full text-left px-3 py-2 text-brand-rose hover:bg-white/10 rounded-md bg-transparent border-0 cursor-pointer text-sm">
                                        Déconnexion
                                    </button>
                                </form>
                            </div>

                        {% else %}
                            <a href="{{ path('app_inscription') }}" class="block px-3 py-2 text-white/80 hover:bg-white/10 rounded-md">S'inscrire</a>
                            <a href="{{ path('app_login') }}" class="block px-3 py-2 text-white font-medium hover:bg-white/10 rounded-md">Connexion</a>
                        {% endif %}
                    </div>
                </div>

            </div>
        </nav>

        <main class="flex-1">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="max-w-7xl mx-auto px-4 mt-4">
                        <div class="rounded-md p-4 text-sm
                            {% if label == 'success' %}bg-brand-vert-light text-brand-vert-dark border border-brand-vert
                            {% elseif label == 'error' %}bg-red-50 text-red-800 border border-red-200
                            {% else %}bg-brand-bleu-light text-brand-bleu-fonce border border-brand-bleu{% endif %}">
                            {{ message }}
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="bg-brand-bleu-fonce text-center text-xs text-white/50 py-4">
            Le Repère des Protocoles &copy; {{ "now"|date("Y") }}
        </footer>

    </body>
</html>
