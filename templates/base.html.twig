<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Le Repère des Protocoles{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-gray-50 flex flex-col">

        <nav class="bg-white shadow-sm border-b border-gray-200" data-controller="navbar">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

                {# ── Barre principale ──────────────────────────────── #}
                <div class="flex justify-between h-16 items-center">

                    {# Logo #}
                    <a href="{{ path('app_home') }}" class="text-base sm:text-xl font-semibold text-blue-700 shrink-0">
                        Le Repère des Protocoles
                    </a>

                    {# Ordinateur (lg+) : tous les liens en ligne #}
                    <div class="hidden lg:flex items-center gap-4 text-sm">
                        {% if app.user %}
                            <a href="{{ path('profil_index') }}" class="text-gray-600 hover:underline">
                                {{ app.user.prenom }} {{ app.user.nom }}
                            </a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin_demande_index') }}" class="text-blue-600 hover:underline">Demandes</a>
                                <a href="{{ path('admin_utilisateur_index') }}" class="text-blue-600 hover:underline">Utilisateurs</a>
                                <a href="{{ path('admin_profession_index') }}" class="text-blue-600 hover:underline">Professions</a>
                            {% endif %}
                            {% if is_granted('ROLE_MODERATEUR') %}
                                <a href="{{ path('moderateur_domaine_index') }}" class="text-blue-600 hover:underline">Domaines</a>
                                <a href="{{ path('moderateur_rubrique_index') }}" class="text-blue-600 hover:underline">Rubriques</a>
                                <a href="{{ path('moderateur_theme_index') }}" class="text-blue-600 hover:underline">Thèmes</a>
                                <a href="{{ path('moderateur_protocole_index') }}" class="text-blue-600 hover:underline">Protocoles</a>
                            {% endif %}
                            <a href="{{ path('navigation_domaines') }}" class="text-blue-600 hover:underline">Parcourir</a>
                            <form action="{{ path('app_logout') }}" method="post" class="inline">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                <button type="submit" class="text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer text-sm font-normal">Déconnexion</button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_inscription') }}" class="text-gray-600 hover:underline">S'inscrire</a>
                            <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">Connexion</a>
                        {% endif %}
                    </div>

                    {# Tablette + Téléphone (< lg) : liens rapides + hamburger #}
                    <div class="flex lg:hidden items-center gap-3">

                        {# Tablette uniquement (md à lg) : nom + Parcourir en ligne #}
                        <div class="hidden md:flex items-center gap-3 text-sm">
                            {% if app.user %}
                                <a href="{{ path('profil_index') }}" class="text-gray-600 hover:underline">
                                    {{ app.user.prenom }} {{ app.user.nom }}
                                </a>
                                <a href="{{ path('navigation_domaines') }}" class="text-blue-600 hover:underline">Parcourir</a>
                            {% else %}
                                <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">Connexion</a>
                            {% endif %}
                        </div>

                        {# Bouton hamburger #}
                        <button
                            type="button"
                            data-action="click->navbar#toggle"
                            class="p-2 rounded-md text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
                            aria-label="Ouvrir le menu"
                        >
                            <svg data-navbar-target="iconOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                            </svg>
                            <svg data-navbar-target="iconClose" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>

                    </div>
                </div>

                {# ── Menu déroulant (téléphone + tablette) ─────────── #}
                <div data-navbar-target="menu" class="hidden lg:hidden border-t border-gray-100">
                    <div class="py-3 flex flex-col gap-0.5 text-sm">
                        {% if app.user %}

                            {# Profil avec avatar #}
                            <a href="{{ path('profil_index') }}"
                               class="flex items-center gap-2 px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-md font-medium">
                                <span class="w-7 h-7 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 text-xs font-bold shrink-0 select-none">
                                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                                </span>
                                {{ app.user.prenom }} {{ app.user.nom }}
                            </a>

                            <a href="{{ path('navigation_domaines') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">
                                Parcourir les protocoles
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide">Administration</p>
                                <a href="{{ path('admin_demande_index') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Demandes</a>
                                <a href="{{ path('admin_utilisateur_index') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Utilisateurs</a>
                                <a href="{{ path('admin_profession_index') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Professions</a>
                            {% endif %}

                            {% if is_granted('ROLE_MODERATEUR') %}
                                <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide">Modération</p>
                                <a href="{{ path('moderateur_domaine_index') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Domaines</a>
                                <a href="{{ path('moderateur_rubrique_index') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Rubriques</a>
                                <a href="{{ path('moderateur_theme_index') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Thèmes</a>
                                <a href="{{ path('moderateur_protocole_index') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Protocoles</a>
                            {% endif %}

                            <div class="mt-2 pt-2 border-t border-gray-100">
                                <form action="{{ path('app_logout') }}" method="post">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                    <button type="submit" class="w-full text-left px-3 py-2 text-red-600 hover:bg-red-50 rounded-md bg-transparent border-0 cursor-pointer text-sm">
                                        Déconnexion
                                    </button>
                                </form>
                            </div>

                        {% else %}
                            <a href="{{ path('app_inscription') }}" class="block px-3 py-2 text-gray-600 hover:bg-gray-50 rounded-md">S'inscrire</a>
                            <a href="{{ path('app_login') }}" class="block px-3 py-2 text-blue-600 hover:bg-blue-50 rounded-md">Connexion</a>
                        {% endif %}
                    </div>
                </div>

            </div>
        </nav>

        <main class="flex-1">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="max-w-7xl mx-auto px-4 mt-4">
                        <div class="rounded-md p-4 text-sm
                            {% if label == 'success' %}bg-green-50 text-green-800 border border-green-200
                            {% elseif label == 'error' %}bg-red-50 text-red-800 border border-red-200
                            {% else %}bg-blue-50 text-blue-800 border border-blue-200{% endif %}">
                            {{ message }}
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="bg-white border-t border-gray-200 text-center text-xs text-gray-400 py-4">
            Le Repère des Protocoles &copy; {{ "now"|date("Y") }}
        </footer>

    </body>
</html>
