{% extends 'base.html.twig' %}

{% block title %}Parcourir les protocoles{% endblock %}

{# Point d'entrée de la navigation : liste tous les domaines disponibles.
   Accessible uniquement aux utilisateurs connectés (ROLE_USER, contrôlé dans NavigationController). #}
{% block body %}
<div class="max-w-5xl mx-auto px-4 py-8">

    <h1 class="text-2xl font-bold text-gray-800 mb-2">Domaines médicaux</h1>
    <p class="text-gray-500 text-sm mb-8">Choisissez un domaine pour accéder aux protocoles.</p>

    {% if domaines is empty %}
        <p class="text-gray-500">Aucun domaine disponible pour l'instant.</p>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for domaine in domaines %}
                <a href="{{ path('navigation_domaine', {slug: domaine.slug}) }}"
                   class="block bg-white rounded-lg shadow-sm border-t-4 border-brand-bleu-fonce border border-gray-200 p-5 hover:shadow-md transition-all">
                    <h2 class="font-semibold text-gray-800 mb-1">{{ domaine.nom }}</h2>
                    {% if domaine.description %}
                        {# Tronque la description à 100 caractères avec "…" via le filtre Symfony String #}
                        <p class="text-gray-500 text-sm">{{ domaine.description|u.truncate(100, '…') }}</p>
                    {% endif %}
                    <p class="text-brand-bleu text-xs mt-3">{{ domaine.rubriques|length }} rubrique(s) →</p>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
