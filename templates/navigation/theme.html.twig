{% extends 'base.html.twig' %}

{% block title %}{{ theme.nom }}{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 py-8">

    {# Fil d'Ariane : Domaines > [domaine(s)] > [rubrique] > [thème actuel]
       Traversée des relations : theme → rubrique → domaines (relation ManyToMany).
       On boucle sur theme.rubrique.domaines car une rubrique peut appartenir à plusieurs domaines. #}
    <nav class="text-sm text-gray-500 mb-6">
        <a href="{{ path('navigation_domaines') }}" class="hover:underline">Domaines</a>
        {% for domaine in theme.rubrique.domaines %}
            <span class="mx-2">›</span>
            <a href="{{ path('navigation_domaine', {slug: domaine.slug}) }}" class="hover:underline">{{ domaine.nom }}</a>
        {% endfor %}
        <span class="mx-2">›</span>
        <a href="{{ path('navigation_rubrique', {slug: theme.rubrique.slug}) }}" class="hover:underline">{{ theme.rubrique.nom }}</a>
        <span class="mx-2">›</span>
        <span class="text-gray-800">{{ theme.nom }}</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-800 mb-6">{{ theme.nom }}</h1>

    {% if theme.protocoles is empty %}
        <p class="text-gray-500">Aucun protocole dans ce thème.</p>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for protocole in theme.protocoles %}
                <a href="{{ path('navigation_protocole', {slug: protocole.slug}) }}"
                   class="block bg-white rounded-lg shadow-sm border-t-4 border-brand-bleu-fonce border border-gray-200 overflow-hidden hover:shadow-md transition-all">
                    {# vich_uploader_asset() génère l'URL publique du fichier uploadé
                       à partir du mapping VichUploader défini dans config/packages/vich_uploader.yaml #}
                    {% if protocole.imageFilename %}
                        <img src="{{ vich_uploader_asset(protocole, 'imageFile') }}"
                             alt="{{ protocole.titre }}"
                             class="w-full h-32 object-cover">
                    {% else %}
                        <div class="w-full h-32 bg-brand-bleu-fonce-light flex items-center justify-center">
                            <span class="text-brand-bleu-fonce text-xs opacity-50">Pas d'image</span>
                        </div>
                    {% endif %}
                    <div class="p-4">
                        <h2 class="font-semibold text-gray-800 text-sm">{{ protocole.titre }}</h2>
                        {% if protocole.pdfFilename %}
                            <p class="text-brand-bleu text-xs mt-2">PDF disponible</p>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
