{% extends 'base.html.twig' %}

{% block title %}{{ protocole.titre }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-8">

    <nav class="text-sm text-gray-500 mb-6">
        <a href="{{ path('navigation_domaines') }}" class="hover:underline">Domaines</a>
        {% for domaine in protocole.theme.rubrique.domaines %}
            <span class="mx-2">›</span>
            <a href="{{ path('navigation_domaine', {slug: domaine.slug}) }}" class="hover:underline">{{ domaine.nom }}</a>
        {% endfor %}
        <span class="mx-2">›</span>
        <a href="{{ path('navigation_rubrique', {slug: protocole.theme.rubrique.slug}) }}" class="hover:underline">{{ protocole.theme.rubrique.nom }}</a>
        <span class="mx-2">›</span>
        <a href="{{ path('navigation_theme', {slug: protocole.theme.slug}) }}" class="hover:underline">{{ protocole.theme.nom }}</a>
        <span class="mx-2">›</span>
        <span class="text-gray-800">{{ protocole.titre }}</span>
    </nav>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">

        {% if protocole.imageFilename %}
            <a href="{{ vich_uploader_asset(protocole, 'imageFile') }}"
               target="_blank"
               title="Voir l'image en taille réelle"
               class="block relative group">
                <img src="{{ vich_uploader_asset(protocole, 'imageFile') }}"
                     alt="{{ protocole.titre }}"
                     class="w-full h-48 object-cover">
                <span class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                    <span class="opacity-0 group-hover:opacity-100 bg-white/90 text-gray-700 text-xs px-3 py-1 rounded-full transition-opacity">
                        Voir en taille réelle
                    </span>
                </span>
            </a>
        {% endif %}

        <div class="p-6">
            <h1 class="text-2xl font-bold text-gray-800 mb-1">{{ protocole.titre }}</h1>

            <p class="text-xs text-gray-400 mb-4">
                Mis à jour le {{ protocole.updatedAt|date('d/m/Y') }}
            </p>

            {% if protocole.description %}
                <p class="text-gray-600 mb-6">{{ protocole.description }}</p>
            {% endif %}

            {% if protocole.pdfFilename %}
                <a href="{{ vich_uploader_asset(protocole, 'pdfFile') }}"
                   download
                   class="inline-block bg-blue-600 text-white px-5 py-2.5 rounded-md text-sm font-medium hover:bg-blue-700">
                    Télécharger le PDF
                </a>
            {% else %}
                <p class="text-gray-400 text-sm italic">Aucun PDF disponible pour ce protocole.</p>
            {% endif %}
        </div>

    </div>

    <div class="mt-4 text-sm">
        <a href="{{ path('navigation_theme', {slug: protocole.theme.slug}) }}"
           class="text-blue-600 hover:underline">
            ← Retour aux protocoles de {{ protocole.theme.nom }}
        </a>
    </div>

</div>
{% endblock %}
