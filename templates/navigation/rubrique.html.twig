{% extends 'base.html.twig' %}

{% block title %}{{ rubrique.nom }}{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 py-8">

    <nav class="text-sm text-gray-500 mb-6">
        <a href="{{ path('navigation_domaines') }}" class="hover:underline">Domaines</a>
        {% for domaine in rubrique.domaines %}
            <span class="mx-2">›</span>
            <a href="{{ path('navigation_domaine', {slug: domaine.slug}) }}" class="hover:underline">{{ domaine.nom }}</a>
        {% endfor %}
        <span class="mx-2">›</span>
        <span class="text-gray-800">{{ rubrique.nom }}</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-800 mb-2">{{ rubrique.nom }}</h1>
    {% if rubrique.description %}
        <p class="text-gray-600 mb-6">{{ rubrique.description }}</p>
    {% endif %}

    {% if rubrique.themes is empty %}
        <p class="text-gray-500">Aucun thème dans cette rubrique.</p>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% for theme in rubrique.themes %}
                <a href="{{ path('navigation_theme', {slug: theme.slug}) }}"
                   class="block bg-white rounded-lg shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-blue-300 transition-all">
                    <h2 class="font-semibold text-gray-800 mb-1">{{ theme.nom }}</h2>
                    <p class="text-blue-600 text-xs mt-3">{{ theme.protocoles|length }} protocole(s) →</p>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
