{% extends 'base.html.twig' %}

{% block title %}{{ domaine.nom }}{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 py-8">

    {# Fil d'Ariane : Domaines > [domaine actuel] #}
    <nav class="text-sm text-gray-500 mb-6">
        <a href="{{ path('navigation_domaines') }}" class="hover:underline">Domaines</a>
        <span class="mx-2">›</span>
        <span class="text-gray-800">{{ domaine.nom }}</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-800 mb-2">{{ domaine.nom }}</h1>
    {% if domaine.description %}
        <p class="text-gray-600 mb-6">{{ domaine.description }}</p>
    {% endif %}

    {# Liste les rubriques du domaine, triées par nom (OrderBy défini dans l'entité Domaine) #}
    {% if domaine.rubriques is empty %}
        <p class="text-gray-500">Aucune rubrique dans ce domaine.</p>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% for rubrique in domaine.rubriques %}
                <a href="{{ path('navigation_rubrique', {slug: rubrique.slug}) }}"
                   class="block bg-white rounded-lg shadow-sm border-t-4 border-brand-bleu-fonce border border-gray-200 p-5 hover:shadow-md transition-all">
                    <h2 class="font-semibold text-gray-800 mb-1">{{ rubrique.nom }}</h2>
                    {% if rubrique.description %}
                        <p class="text-gray-500 text-sm">{{ rubrique.description|u.truncate(100, '…') }}</p>
                    {% endif %}
                    <p class="text-brand-bleu text-xs mt-3">{{ rubrique.themes|length }} thème(s) →</p>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
