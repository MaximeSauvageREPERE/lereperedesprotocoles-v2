{% extends 'base.html.twig' %}

{% block title %}Lien invalide{% endblock %}

{# Page affichée quand le token de confirmation email est invalide ou expiré (> 24h).
   Actuellement inaccessible car la vérification email est désactivée. #}
{% block body %}
<div class="max-w-lg mx-auto px-4 py-16 text-center">
    <div class="text-5xl mb-6">⚠️</div>
    <h1 class="text-2xl font-bold text-gray-800 mb-3">Lien invalide ou expiré</h1>
    <p class="text-gray-600 mb-6">
        Ce lien de confirmation est invalide ou a expiré (validité 24 heures).
    </p>
    <a href="{{ path('app_inscription') }}" class="inline-block bg-brand-bleu-fonce hover:bg-brand-bleu-fonce-dark text-white text-sm font-medium py-2 px-5 rounded-md transition-colors">
        Faire une nouvelle demande
    </a>
</div>
{% endblock %}
