{% extends 'base.html.twig' %}

{% block title %}Mon profil — Le Repère des Protocoles{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-10">

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Mon profil</h1>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">

        {# En-tête avec avatar initiales — app.user est l'utilisateur connecté (injection Twig globale) #}
        <div class="bg-brand-bleu-fonce px-4 sm:px-6 py-6 sm:py-8 flex items-center gap-3 sm:gap-4">
            <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-full bg-white/20 flex items-center justify-center text-white text-xl sm:text-2xl font-bold select-none shrink-0">
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            </div>
            <div>
                <p class="text-white text-xl font-semibold">{{ app.user.prenom }} {{ app.user.nom }}</p>
                <p class="text-white/70 text-sm">{{ app.user.email }}</p>
            </div>
        </div>

        <div class="divide-y divide-gray-100">

            <div class="px-6 py-4 flex justify-between items-center">
                <span class="text-sm font-medium text-gray-500">Profession</span>
                <span class="text-sm text-gray-900">{{ app.user.profession.nom }}</span>
            </div>

            <div class="px-6 py-4 flex justify-between items-center">
                <span class="text-sm font-medium text-gray-500">Rôle</span>
                {# is_granted() respecte la hiérarchie des rôles : ROLE_ADMIN > ROLE_MODERATEUR > ROLE_USER #}
                <span class="text-xs font-medium px-2 py-1 rounded-full
                    {% if is_granted('ROLE_ADMIN') %}bg-purple-100 text-purple-800
                    {% elseif is_granted('ROLE_MODERATEUR') %}bg-yellow-100 text-yellow-800
                    {% else %}bg-brand-bleu-light text-brand-bleu-fonce{% endif %}">
                    {% if is_granted('ROLE_ADMIN') %}Administrateur
                    {% elseif is_granted('ROLE_MODERATEUR') %}Modérateur
                    {% else %}Utilisateur{% endif %}
                </span>
            </div>

            <div class="px-6 py-4 flex justify-between items-center">
                <span class="text-sm font-medium text-gray-500">Membre depuis</span>
                <span class="text-sm text-gray-900">{{ app.user.createdAt|date('d/m/Y') }}</span>
            </div>

        </div>
    </div>

    <div class="mt-6">
        <a href="{{ path('navigation_domaines') }}"
           class="inline-flex items-center gap-2 bg-brand-bleu-fonce hover:bg-brand-bleu-fonce-dark text-white text-sm font-medium px-4 py-2 rounded-md transition-colors">
            Parcourir les protocoles
        </a>
    </div>

</div>
{% endblock %}
