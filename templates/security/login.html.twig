{% extends 'base.html.twig' %}

{% block title %}Connexion — Le Repère des Protocoles{% endblock %}

{% block body %}
<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Connexion</h1>
            <p class="text-sm text-gray-500 mt-1">Accédez à vos protocoles médicaux</p>
        </div>

        {% if error %}
            <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-4 text-sm text-red-800">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" class="bg-white shadow-sm rounded-lg border-t-4 border-brand-bleu-fonce border border-gray-200 p-8 space-y-5">

            <div>
                <label for="inputEmail" class="block text-sm font-medium text-gray-700 mb-1">
                    Adresse email
                </label>
                <input
                    type="email"
                    id="inputEmail"
                    name="_username"
                    value="{{ last_username }}"
                    autocomplete="email"
                    required
                    autofocus
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu focus:border-brand-bleu"
                >
            </div>

            <div>
                <label for="inputPassword" class="block text-sm font-medium text-gray-700 mb-1">
                    Mot de passe
                </label>
                <input
                    type="password"
                    id="inputPassword"
                    name="_password"
                    autocomplete="current-password"
                    required
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu focus:border-brand-bleu"
                >
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button
                type="submit"
                class="w-full rounded-md bg-brand-bleu-fonce px-4 py-2 text-sm font-medium text-white hover:bg-brand-bleu-fonce-dark focus:outline-none focus:ring-2 focus:ring-brand-bleu focus:ring-offset-2 transition-colors"
            >
                Se connecter
            </button>

        </form>

        <p class="text-center text-sm text-gray-500 mt-6">
            Pas encore de compte ? <a href="{{ path('app_inscription') }}" class="text-brand-bleu hover:underline">Demander l'accès</a>
        </p>

    </div>
</div>
{% endblock %}
