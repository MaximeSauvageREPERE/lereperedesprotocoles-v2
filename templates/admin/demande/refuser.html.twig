{% extends 'base.html.twig' %}

{% block title %}Refuser la demande{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto px-4 py-10">

    <a href="{{ path('admin_demande_index') }}" class="text-sm text-brand-bleu hover:underline mb-6 inline-block">
        ← Retour aux demandes
    </a>

    <h1 class="text-xl font-bold text-gray-800 mb-1">Refuser la demande</h1>
    <p class="text-gray-500 text-sm mb-8">
        {{ demande.prenom }} {{ demande.nom }} — {{ demande.email }}
    </p>

    {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}

    <div>
        {{ form_label(form.motifRejet, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
        {{ form_widget(form.motifRejet, {'attr': {'class': 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400'}}) }}
        {{ form_errors(form.motifRejet) }}
        <p class="text-xs text-gray-400 mt-1">Ce motif sera inclus dans l'email envoyé au demandeur.</p>
    </div>

    <div class="flex gap-3">
        <button type="submit" class="bg-red-600 hover:bg-red-700 text-white text-sm font-medium py-2 px-5 rounded-md transition-colors">
            Confirmer le refus
        </button>
        <a href="{{ path('admin_demande_index') }}" class="text-sm text-gray-600 hover:underline self-center">
            Annuler
        </a>
    </div>

    {{ form_end(form) }}

</div>
{% endblock %}
