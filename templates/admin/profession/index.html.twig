{% extends 'base.html.twig' %}

{% block title %}Professions{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-10">

    <h1 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4">Professions ({{ pagination.getTotalItemCount() }})</h1>

    <div class="mb-6 flex flex-wrap items-center gap-2">
        <form method="get" class="flex flex-wrap items-center gap-2">
            <input type="text"
                   name="q"
                   value="{{ q }}"
                   placeholder="Rechercher une profession…"
                   class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu w-64">
            <button type="submit"
                    class="bg-gray-100 border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm hover:bg-gray-200">
                Rechercher
            </button>
            {% if q %}
                <a href="{{ app.request.pathinfo }}"
                   class="text-sm text-gray-500 hover:text-gray-700">
                    Effacer
                </a>
            {% endif %}
        </form>
        <a href="{{ path('admin_profession_new') }}"
           class="ml-auto bg-brand-bleu-fonce text-white text-sm font-medium px-4 py-2 rounded-md hover:bg-brand-bleu-fonce-dark">
            + Nouvelle profession
        </a>
    </div>

    {% if pagination.getTotalItemCount() == 0 %}
        {% if q %}
            <p class="text-gray-500">Aucun résultat pour « {{ q }} ».</p>
        {% else %}
            <p class="text-gray-500">Aucune profession.</p>
        {% endif %}
    {% else %}
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Nom</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Slug</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Utilisateurs</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Demandes</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for profession in pagination %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-3 font-medium text-gray-800">{{ profession.nom }}</td>
                            <td class="px-4 py-3 text-gray-500 font-mono text-xs">{{ profession.slug }}</td>
                            <td class="px-4 py-3 text-gray-600">{{ profession.users|length }}</td>
                            <td class="px-4 py-3 text-gray-600">{{ profession.demandesInscription|length }}</td>
                            <td class="px-4 py-3">
                                <div class="flex gap-2 justify-end">
                                    <a href="{{ path('admin_profession_edit', {id: profession.id}) }}"
                                       class="bg-brand-bleu-fonce-light text-brand-bleu-fonce hover:bg-brand-bleu-fonce hover:text-white text-xs font-medium py-1.5 px-3 rounded transition-colors">
                                        Modifier
                                    </a>
                                    {# Le bouton Supprimer est désactivé si la profession a des utilisateurs
                                       ou des demandes rattachées — la suppression est bloquée côté contrôleur aussi #}
                                    {% if profession.users|length == 0 and profession.demandesInscription|length == 0 %}
                                        <form method="post" action="{{ path('admin_profession_delete', {id: profession.id}) }}"
                                              onsubmit="return confirm('Supprimer la profession « {{ profession.nom }} » ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_profession_' ~ profession.id) }}">
                                            <button type="submit"
                                                    class="bg-red-50 text-red-600 hover:bg-red-600 hover:text-white text-xs font-medium py-1.5 px-3 rounded transition-colors">
                                                Supprimer
                                            </button>
                                        </form>
                                    {% else %}
                                        {# Bouton grisé non cliquable (cursor-not-allowed) avec explication au survol #}
                                        <span class="bg-gray-50 text-gray-300 text-xs font-medium py-1.5 px-3 rounded cursor-not-allowed" title="Des utilisateurs ou demandes sont rattachés à cette profession">
                                            Supprimer
                                        </span>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
          </div>
        </div>
        <div class="mt-4 flex justify-center">{{ knp_pagination_render(pagination) }}</div>
    {% endif %}

</div>
{% endblock %}
