{% extends 'base.html.twig' %}

{% block title %}Modifier {{ profession.nom }}{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto px-4 py-10">

    <div class="mb-6">
        <a href="{{ path('admin_profession_index') }}" class="text-sm text-gray-500 hover:underline">← Retour aux professions</a>
    </div>

    <h1 class="text-2xl font-bold text-gray-800 mb-2">Modifier la profession</h1>
    <p class="text-sm text-gray-500 mb-8">Slug actuel : <code class="font-mono bg-gray-100 px-1 rounded">{{ profession.slug }}</code></p>

    {{ form_start(form, {attr: {class: 'bg-white shadow-sm rounded-lg border-t-4 border-brand-bleu-fonce border border-gray-200 p-8 space-y-5'}}) }}

        <div>
            {{ form_label(form.nom, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.nom, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu'}}) }}
            {{ form_errors(form.nom) }}
            <p class="text-xs text-gray-400 mt-1">Le slug sera régénéré automatiquement à la sauvegarde.</p>
        </div>

        <div class="flex justify-end gap-3 pt-2">
            <a href="{{ path('admin_profession_index') }}"
               class="px-4 py-2 rounded-md text-sm font-medium text-gray-600 border border-gray-300 bg-gray-100 hover:bg-gray-200 transition-colors">
                Annuler
            </a>
            <button type="submit"
                    class="bg-brand-bleu-fonce text-white text-sm font-medium px-4 py-2 rounded-md hover:bg-brand-bleu-fonce-dark">
                Enregistrer
            </button>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
