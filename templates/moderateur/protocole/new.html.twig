{% extends 'base.html.twig' %}

{% block title %}Nouveau protocole{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 py-8">

    <div class="mb-6">
        <a href="{{ path('moderateur_protocole_index') }}" class="text-sm text-gray-500 hover:underline">← Protocoles</a>
        <h1 class="text-2xl font-bold text-gray-800 mt-2">Nouveau protocole</h1>
    </div>

    {{ form_start(form, {attr: {class: 'bg-white shadow-sm rounded-lg border-t-4 border-brand-bleu-fonce border border-gray-200 p-8 space-y-5', enctype: 'multipart/form-data'}}) }}

        <div>
            {{ form_label(form.titre, 'Titre', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.titre, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu'}}) }}
            {{ form_errors(form.titre) }}
        </div>

        <div>
            {{ form_label(form.description, 'Description', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.description, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div>
            {{ form_label(form.theme, 'Thème', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.theme, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu'}}) }}
            {{ form_errors(form.theme) }}
        </div>

        <div>
            {{ form_label(form.pdfFile, 'Fichier PDF', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            <div class="border border-gray-200 rounded-md bg-gray-50 px-3 py-2">
                {{ form_widget(form.pdfFile, {attr: {class: 'block w-full text-sm text-gray-500 file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-medium file:bg-brand-bleu-fonce-light file:text-brand-bleu-fonce hover:file:bg-brand-bleu-fonce hover:file:text-white file:cursor-pointer file:transition-colors cursor-pointer'}}) }}
            </div>
            <p class="text-xs text-gray-400 mt-1">PDF uniquement, 10 Mo max.</p>
            {{ form_errors(form.pdfFile) }}
        </div>

        <div>
            {{ form_label(form.imageFile, 'Image de couverture', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            <div class="border border-gray-200 rounded-md bg-gray-50 px-3 py-2">
                {{ form_widget(form.imageFile, {attr: {class: 'block w-full text-sm text-gray-500 file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-medium file:bg-brand-bleu-fonce-light file:text-brand-bleu-fonce hover:file:bg-brand-bleu-fonce hover:file:text-white file:cursor-pointer file:transition-colors cursor-pointer'}}) }}
            </div>
            <p class="text-xs text-gray-400 mt-1">JPG, PNG ou WebP, 20 Mo max.</p>
            {{ form_errors(form.imageFile) }}
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="bg-brand-bleu-fonce text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-brand-bleu-fonce-dark">
                Créer
            </button>
            <a href="{{ path('moderateur_protocole_index') }}"
               class="px-4 py-2 rounded-md text-sm font-medium text-gray-600 border border-gray-300 bg-gray-100 hover:bg-gray-200 transition-colors">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
