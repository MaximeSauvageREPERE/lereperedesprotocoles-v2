{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ protocole.titre }}{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 py-8">

    <div class="mb-6">
        <a href="{{ path('moderateur_protocole_index') }}" class="text-sm text-gray-500 hover:underline">← Protocoles</a>
        <h1 class="text-2xl font-bold text-gray-800 mt-2">Modifier le protocole</h1>
    </div>

    {{ form_start(form, {attr: {class: 'bg-white shadow-sm rounded-lg p-6 space-y-5', enctype: 'multipart/form-data'}}) }}

        <div>
            {{ form_label(form.titre, 'Titre', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.titre, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.titre) }}
        </div>

        <div>
            {{ form_label(form.description, 'Description', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.description, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div>
            {{ form_label(form.theme, 'Thème', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.theme, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.theme) }}
        </div>

        <div>
            {{ form_label(form.pdfFile, 'Fichier PDF', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {% if protocole.pdfFilename %}
                <p class="text-xs text-gray-500 mb-1">
                    Actuel : <a href="{{ vich_uploader_asset(protocole, 'pdfFile') }}" target="_blank" class="text-blue-600 hover:underline">{{ protocole.pdfFilename }}</a>
                </p>
            {% endif %}
            {{ form_widget(form.pdfFile) }}
            <p class="text-xs text-gray-400 mt-1">PDF uniquement, 10 Mo max. Laisser vide pour conserver l'actuel.</p>
            {{ form_errors(form.pdfFile) }}
        </div>

        <div>
            {{ form_label(form.imageFile, 'Image de couverture', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {% if protocole.imageFilename %}
                <img src="{{ vich_uploader_asset(protocole, 'imageFile') }}"
                     alt="{{ protocole.titre }}"
                     class="h-20 w-20 object-cover rounded mb-2">
            {% endif %}
            {{ form_widget(form.imageFile) }}
            <p class="text-xs text-gray-400 mt-1">JPG, PNG ou WebP, 20 Mo max. Laisser vide pour conserver l'actuelle.</p>
            {{ form_errors(form.imageFile) }}
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700">
                Enregistrer
            </button>
            <a href="{{ path('moderateur_protocole_index') }}"
               class="px-4 py-2 rounded-md text-sm font-medium text-gray-600 hover:bg-gray-100">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
