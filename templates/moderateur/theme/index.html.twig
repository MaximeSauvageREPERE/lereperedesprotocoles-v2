{% extends 'base.html.twig' %}

{% block title %}Thèmes — Modération{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-8">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Thèmes</h1>
        <a href="{{ path('moderateur_theme_new') }}"
           class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700">
            + Nouveau thème
        </a>
    </div>

    {% if themes is empty %}
        <p class="text-gray-500">Aucun thème pour l'instant.</p>
    {% else %}
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nom</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rubrique</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Protocoles</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for theme in themes %}
                        <tr>
                            <td class="px-6 py-4 font-medium text-gray-900">{{ theme.nom }}</td>
                            <td class="px-6 py-4 text-gray-600 text-sm">{{ theme.rubrique.nom }}</td>
                            <td class="px-6 py-4 text-gray-600 text-sm">{{ theme.protocoles|length }}</td>
                            <td class="px-6 py-4 text-right space-x-3 text-sm">
                                <a href="{{ path('moderateur_theme_edit', {id: theme.id}) }}"
                                   class="text-blue-600 hover:underline">Modifier</a>
                                <form method="post"
                                      action="{{ path('moderateur_theme_delete', {id: theme.id}) }}"
                                      class="inline"
                                      onsubmit="return confirm('Supprimer ce thème ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_theme_' ~ theme.id) }}">
                                    <button type="submit" class="text-red-600 hover:underline">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>
{% endblock %}
