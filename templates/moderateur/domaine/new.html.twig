{% extends 'base.html.twig' %}

{% block title %}Nouveau domaine{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 py-8">

    <div class="mb-6">
        <a href="{{ path('moderateur_domaine_index') }}" class="text-sm text-gray-500 hover:underline">← Domaines</a>
        <h1 class="text-2xl font-bold text-gray-800 mt-2">Nouveau domaine</h1>
    </div>

    {{ form_start(form, {attr: {class: 'bg-white shadow-sm rounded-lg p-6 space-y-5'}}) }}

        <div>
            {{ form_label(form.nom, 'Nom', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.nom, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div>
            {{ form_label(form.description, 'Description', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.description, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700">
                Créer
            </button>
            <a href="{{ path('moderateur_domaine_index') }}"
               class="px-4 py-2 rounded-md text-sm font-medium text-gray-600 hover:bg-gray-100">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
