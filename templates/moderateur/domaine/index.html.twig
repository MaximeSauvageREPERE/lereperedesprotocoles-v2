{% extends 'base.html.twig' %}

{% block title %}Domaines — Modération{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-8">

    <h1 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4">Domaines</h1>

    <div class="mb-6 flex flex-wrap items-center gap-2">
        <form method="get" class="flex flex-wrap items-center gap-2">
            <input type="text"
                   name="q"
                   value="{{ q }}"
                   placeholder="Rechercher un domaine…"
                   class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu w-64">
            <button type="submit"
                    class="bg-gray-100 border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm hover:bg-gray-200">
                Rechercher
            </button>
            {% if q %}
                <a href="{{ app.request.pathinfo }}"
                   class="text-sm text-gray-500 hover:text-gray-700">
                    Effacer
                </a>
            {% endif %}
        </form>
        <a href="{{ path('moderateur_domaine_new') }}"
           class="ml-auto bg-brand-bleu-fonce text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-brand-bleu-fonce-dark">
            + Nouveau domaine
        </a>
    </div>

    {% if pagination.getTotalItemCount() == 0 %}
        {% if q %}
            <p class="text-gray-500">Aucun résultat pour « {{ q }} ».</p>
        {% else %}
            <p class="text-gray-500">Aucun domaine pour l'instant.</p>
        {% endif %}
    {% else %}
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nom</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rubriques</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for domaine in pagination %}
                        <tr>
                            <td class="px-6 py-4 font-medium text-gray-900">{{ domaine.nom }}</td>
                            <td class="px-6 py-4 text-gray-600 text-sm">
                                {# |default('—') évite une erreur si description est null,
                                   |u.truncate(80, '…') coupe à 80 caractères via Symfony String #}
                                {{ domaine.description|default('—')|u.truncate(80, '…') }}
                            </td>
                            <td class="px-6 py-4 text-gray-600 text-sm">{{ domaine.rubriques|length }}</td>
                            <td class="px-6 py-4">
                                <div class="flex gap-2 justify-end">
                                    <a href="{{ path('moderateur_domaine_edit', {id: domaine.id}) }}"
                                       class="bg-brand-bleu-fonce-light text-brand-bleu-fonce hover:bg-brand-bleu-fonce hover:text-white text-xs font-medium py-1.5 px-3 rounded transition-colors">Modifier</a>
                                    <form method="post"
                                          action="{{ path('moderateur_domaine_delete', {id: domaine.id}) }}"
                                          onsubmit="return confirm('Supprimer ce domaine ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_domaine_' ~ domaine.id) }}">
                                        <button type="submit" class="bg-red-50 text-red-600 hover:bg-red-600 hover:text-white text-xs font-medium py-1.5 px-3 rounded transition-colors">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
          </div>
        </div>
        <div class="mt-4 flex justify-center">{{ knp_pagination_render(pagination) }}</div>
    {% endif %}

</div>
{% endblock %}
