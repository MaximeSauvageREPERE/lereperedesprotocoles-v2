{% extends 'base.html.twig' %}

{% block title %}Domaines — Modération{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-8">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
        <h1 class="text-xl sm:text-2xl font-bold text-gray-800">Domaines</h1>
        <a href="{{ path('moderateur_domaine_new') }}"
           class="self-start sm:self-auto bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700">
            + Nouveau domaine
        </a>
    </div>

    {% if domaines is empty %}
        <p class="text-gray-500">Aucun domaine pour l'instant.</p>
    {% else %}
        <div class="bg-white shadow-sm rounded-lg overflow-hidden">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nom</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rubriques</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for domaine in domaines %}
                        <tr>
                            <td class="px-6 py-4 font-medium text-gray-900">{{ domaine.nom }}</td>
                            <td class="px-6 py-4 text-gray-600 text-sm">
                                {{ domaine.description|default('—')|u.truncate(80, '…') }}
                            </td>
                            <td class="px-6 py-4 text-gray-600 text-sm">{{ domaine.rubriques|length }}</td>
                            <td class="px-6 py-4 text-right space-x-3 text-sm">
                                <a href="{{ path('moderateur_domaine_edit', {id: domaine.id}) }}"
                                   class="text-blue-600 hover:underline">Modifier</a>
                                <form method="post"
                                      action="{{ path('moderateur_domaine_delete', {id: domaine.id}) }}"
                                      class="inline"
                                      onsubmit="return confirm('Supprimer ce domaine ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_domaine_' ~ domaine.id) }}">
                                    <button type="submit" class="text-red-600 hover:underline">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
          </div>
        </div>
    {% endif %}

</div>
{% endblock %}
