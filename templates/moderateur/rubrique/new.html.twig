{% extends 'base.html.twig' %}

{% block title %}Nouvelle rubrique{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto px-4 py-8">

    <div class="mb-6">
        <a href="{{ path('moderateur_rubrique_index') }}" class="text-sm text-gray-500 hover:underline">← Rubriques</a>
        <h1 class="text-2xl font-bold text-gray-800 mt-2">Nouvelle rubrique</h1>
    </div>

    {{ form_start(form, {attr: {class: 'bg-white shadow-sm rounded-lg border-t-4 border-brand-bleu-fonce border border-gray-200 p-8 space-y-5'}}) }}

        <div>
            {{ form_label(form.nom, 'Nom', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.nom, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div>
            {{ form_label(form.description, 'Description', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.description, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-bleu'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div>
            {{ form_label(form.domaines, 'Domaines associés', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-2'}}) }}
            <div class="flex flex-wrap gap-2">
                {% for domaine in form.domaines %}
                    <label class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-sm cursor-pointer transition-colors select-none border-gray-200 bg-gray-50 text-gray-600 hover:border-brand-bleu-fonce hover:text-brand-bleu-fonce has-[:checked]:border-brand-bleu-fonce has-[:checked]:bg-brand-bleu-fonce-light has-[:checked]:text-brand-bleu-fonce">
                        {{ form_widget(domaine, {attr: {class: 'sr-only'}}) }}
                        {{ domaine.vars.label }}
                    </label>
                {% endfor %}
            </div>
            {{ form_errors(form.domaines) }}
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="bg-brand-bleu-fonce text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-brand-bleu-fonce-dark">
                Créer
            </button>
            <a href="{{ path('moderateur_rubrique_index') }}"
               class="px-4 py-2 rounded-md text-sm font-medium text-gray-600 hover:bg-gray-100">
                Annuler
            </a>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
